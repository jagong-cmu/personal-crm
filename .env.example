# Copy to .env and fill in. .env is gitignored — never commit real values.

# --- Database (Postgres + pgvector) ---
# Use the NON-SUPERUSER app role so Row-Level Security is actually enforced (a superuser
# bypasses RLS). Create it once: scripts/setup_app_role.sql (see README step 5b).
# Run migrations as the 'crm' owner; run the app/workers as 'crm_app'.
DATABASE_URL=postgresql+psycopg://crm_app:crm_app@localhost:5432/crm

# --- API keys ---
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxx
VOYAGE_API_KEY=pa-xxxxxxxxxxxxxxxxx

# --- Google OAuth (Cloud Console > Credentials > OAuth client, type "Web application") ---
GOOGLE_CLIENT_ID=xxxxxxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=xxxxxxxx
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# --- Token encryption (Fernet) ---
# Decision T12: keep the key SEPARATE from the DB. Preferred: point at a gitignored
# file and leave TOKEN_ENCRYPTION_KEY blank. Generate one with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
TOKEN_ENCRYPTION_KEY_FILE=secrets/token.key
TOKEN_ENCRYPTION_KEY=

# --- Tenancy (single local tenant for now) ---
# Generate with: python -c "import uuid; print(uuid.uuid4())"
DEFAULT_TENANT_ID=00000000-0000-0000-0000-000000000001

# --- Models (pinned; column dim is asserted against VOYAGE_DIM at startup) ---
VOYAGE_MODEL=voyage-3.5
VOYAGE_DIM=1024
# Default claude-opus-4-8 (most capable). For ~5x cheaper synthesis on this
# mostly-summarization task, set claude-sonnet-4-6 — your call on the tradeoff.
ANTHROPIC_MODEL=claude-opus-4-8
RAG_TOP_K=8
